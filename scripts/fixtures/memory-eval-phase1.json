{
  "name": "interaction-memory-live-phase1",
  "description": "Live interaction-memory evaluation set for longer batched writeback sessions, memory-tree quality, retrieval correctness, retrieval speed, and AGENTS.md leakage detection.",
  "batch_size": 3,
  "scenarios": [
    {
      "id": "customer_pine_harbor_long_session",
      "description": "Six Pine Harbor turns should form one healthy customer tree across two writeback batches.",
      "writer_turns": [
        "Pine Harbor billing escalation contact is Mila Hart.",
        "Pine Harbor billing dispute escalation procedure: 1. Open the ledger case. 2. Confirm the dispute packet. 3. Escalate to the billing lead.",
        "Pine Harbor contract renewal owner is Denver Lane.",
        "Pine Harbor refund hold window is 48 hours before escalation.",
        "Pine Harbor settlement dashboard URL is https://dash.example.internal/pine-harbor/settlement.",
        "Pine Harbor urgent finance bridge channel is #pine-harbor-finance-war-room."
      ],
      "expected_entities": [
        {
          "entity_id": "interaction:customer:pine-harbor",
          "entity_type": "customer",
          "canonical_name": "Pine Harbor",
          "expected_active_leaf_count": 6,
          "expected_summary_count_min": 1,
          "expected_memories": [
            {
              "all_terms": [
                "pine harbor",
                "billing",
                "mila hart"
              ]
            },
            {
              "all_terms": [
                "pine harbor",
                "dispute",
                "ledger case"
              ]
            },
            {
              "all_terms": [
                "pine harbor",
                "contract renewal",
                "denver lane"
              ]
            },
            {
              "all_terms": [
                "pine harbor",
                "refund hold",
                "48 hours"
              ]
            },
            {
              "all_terms": [
                "pine harbor",
                "settlement dashboard"
              ]
            },
            {
              "all_terms": [
                "pine harbor",
                "finance bridge"
              ]
            }
          ]
        }
      ],
      "reader_queries": [
        {
          "query": "Who is the Pine Harbor billing escalation contact?",
          "expected_answer_contains": [
            "Mila Hart"
          ],
          "expected_retrieve_contains": [
            "Mila Hart"
          ]
        },
        {
          "query": "What is the Pine Harbor billing dispute escalation procedure?",
          "expected_answer_contains": [
            "Open the ledger case",
            "Confirm the dispute packet",
            "Escalate to the billing lead"
          ],
          "expected_retrieve_contains": [
            "Open the ledger case",
            "Escalate to the billing lead"
          ]
        },
        {
          "query": "How long is the Pine Harbor refund hold window?",
          "expected_answer_contains": [
            "48 hours"
          ],
          "expected_retrieve_contains": [
            "48 hours"
          ]
        }
      ],
      "agents_terms": [
        "Pine Harbor",
        "Mila Hart",
        "Denver Lane"
      ],
      "agents_policy": "forbid"
    },
