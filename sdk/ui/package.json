{
  "name": "@holaboss/ui",
  "version": "0.3.1",
  "license": "Apache-2.0",
  "description": "Shared UI library for holaOS — primitives, layouts, and tokens used by app-builder-sdk dashboards.",
  "keywords": [
    "holaboss",
    "ui",
    "design-system",
    "react",
    "shadcn",
    "tailwind",
    "components"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/holaboss-ai/holaOS.git",
    "directory": "sdk/ui"
  },
  "homepage": "https://github.com/holaboss-ai/holaOS/tree/main/sdk/ui",
  "bugs": "https://github.com/holaboss-ai/holaOS/issues",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css",
    "./tokens.css": "./dist/tokens.css",
    "./themes/holaos.css": "./dist/themes/holaos.css"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "node ../../scripts/remove-paths.mjs dist",
    "typecheck": "tsc --noEmit",
    "test": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.2.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.542.0",
    "next-themes": "^0.4.6",
    "react-day-picker": "^10.0.1",
    "react-resizable-panels": "^4.11.1",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "tailwindcss": "^4.2.1",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3"
  }
}
